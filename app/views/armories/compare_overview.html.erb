<% content_for :title, t('armories.compare_overview.page_title') %>

<div class="container-fluid armory-layout-container">
  <main class="text-center armory-page armory-layout-main">
    <%= render 'locale_switcher' %>
    <%= render 'page_header', heading: t('armories.compare_overview.heading'), icon_class: nil %>

    <%= render 'menu',
               current_page: :compare_overview,
               name: (params[:name_a].presence || params[:name_b].presence),
               name_a: params[:name_a],
               name_b: params[:name_b],
               show_compare_actions: false %>

    <%= render 'compare_search_form',
           form_url: compare_overview_armory_path,
           show_weight_profile_selector: true,
           weight_profile_options: CompareOverviewService.weight_profile_options %>

    <% if @error.present? %>
      <%= render 'error_alert',
                 label: t('armories.compare.alerts.error'),
                 message: @error,
                 icon_class: nil,
                 dismissible: false %>
    <% end %>

    <% if @comparison_ready && @result.present? %>
      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_overview.summary_heading') %></h2>
        </div>
        <div class="armory-section-card__body">
          <div class="row g-3 text-start">
            <% Array(@result[:comparison_cards]).each do |card| %>
              <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 bg-dark border-secondary">
                  <div class="card-body">
                    <div class="small text-muted"><%= t("armories.compare_overview.metrics.#{card[:label_key]}") %></div>
                    <div class="mt-2">
                      <span class="fw-semibold"><%= @result[:name_a] %>:</span>
                      <span><%= number_with_delimiter(card[:value_a]) %></span>
                    </div>
                    <div>
                      <span class="fw-semibold"><%= @result[:name_b] %>:</span>
                      <span><%= number_with_delimiter(card[:value_b]) %></span>
                    </div>
                    <div class="mt-2 <%= card[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= card[:diff].to_f >= 0 ? '+' : '' %><%= number_with_delimiter(card[:diff]) %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </section>

      <% weighted = @result[:weighted_profiles] || {} %>
      <% pve = weighted[:pve] || {} %>
      <% pvp = weighted[:pvp] || {} %>
      <% overall = weighted[:overall] || {} %>
      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_overview.weighted_heading') %></h2>
        </div>
        <div class="armory-section-card__body">
          <div class="row g-3 text-start mb-3">
            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <div class="small text-muted"><%= t('armories.compare_overview.weighted.pve') %></div>
                  <div class="mt-2"><span class="fw-semibold"><%= @result[:name_a] %>:</span> <span><%= number_with_precision(pve[:score_a], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div><span class="fw-semibold"><%= @result[:name_b] %>:</span> <span><%= number_with_precision(pve[:score_b], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div class="mt-2 <%= pve[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                    <%= pve[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(pve[:diff], precision: 2, strip_insignificant_zeros: true) %>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <div class="small text-muted"><%= t('armories.compare_overview.weighted.pvp') %></div>
                  <div class="mt-2"><span class="fw-semibold"><%= @result[:name_a] %>:</span> <span><%= number_with_precision(pvp[:score_a], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div><span class="fw-semibold"><%= @result[:name_b] %>:</span> <span><%= number_with_precision(pvp[:score_b], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div class="mt-2 <%= pvp[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                    <%= pvp[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(pvp[:diff], precision: 2, strip_insignificant_zeros: true) %>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <div class="small text-muted"><%= t('armories.compare_overview.weighted.overall') %></div>
                  <div class="mt-2"><span class="fw-semibold"><%= @result[:name_a] %>:</span> <span><%= number_with_precision(overall[:score_a], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div><span class="fw-semibold"><%= @result[:name_b] %>:</span> <span><%= number_with_precision(overall[:score_b], precision: 2, strip_insignificant_zeros: true) %></span></div>
                  <div class="mt-2 <%= overall[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                    <%= overall[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(overall[:diff], precision: 2, strip_insignificant_zeros: true) %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="table-responsive mb-3">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th><%= t('armories.compare_overview.weighted.table.metric') %> (<%= t('armories.compare_overview.weighted.pve') %>)</th>
                  <th class="text-center"><%= t('armories.compare_overview.weighted.table.weight') %></th>
                  <th class="text-center"><%= @result[:name_a] %></th>
                  <th class="text-center"><%= @result[:name_b] %></th>
                  <th class="text-center"><%= t('armories.compare_overview.table.diff') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(pve[:contributions]).each do |row| %>
                  <tr>
                    <td><%= t("armories.compare_overview.metrics.#{row[:label_key]}") %></td>
                    <td class="text-center"><%= number_with_precision(row[:weight].to_f * 100.0, precision: 0) %>%</td>
                    <td class="text-center"><%= number_with_precision(row[:weighted_a], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center"><%= number_with_precision(row[:weighted_b], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center <%= row[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= row[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(row[:diff], precision: 2, strip_insignificant_zeros: true) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th><%= t('armories.compare_overview.weighted.table.metric') %> (<%= t('armories.compare_overview.weighted.pvp') %>)</th>
                  <th class="text-center"><%= t('armories.compare_overview.weighted.table.weight') %></th>
                  <th class="text-center"><%= @result[:name_a] %></th>
                  <th class="text-center"><%= @result[:name_b] %></th>
                  <th class="text-center"><%= t('armories.compare_overview.table.diff') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(pvp[:contributions]).each do |row| %>
                  <tr>
                    <td><%= t("armories.compare_overview.metrics.#{row[:label_key]}") %></td>
                    <td class="text-center"><%= number_with_precision(row[:weight].to_f * 100.0, precision: 0) %>%</td>
                    <td class="text-center"><%= number_with_precision(row[:weighted_a], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center"><%= number_with_precision(row[:weighted_b], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center <%= row[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= row[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(row[:diff], precision: 2, strip_insignificant_zeros: true) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <% collection_macro = @result[:collection_macro] || {} %>
      <% collection_a = collection_macro[:a] || {} %>
      <% collection_b = collection_macro[:b] || {} %>
      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_overview.collection_heading') %></h2>
        </div>
        <div class="armory-section-card__body">
          <div class="row g-3 text-start mb-3">
            <div class="col-12 col-lg-6">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <h3 class="h6 mb-3"><%= @result[:name_a] %></h3>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.total') %>:</span> <strong><%= collection_a[:total].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.completed') %>:</span> <strong><%= collection_a[:completed].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.in_progress') %>:</span> <strong><%= collection_a[:in_progress].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.near') %>:</span> <strong><%= collection_a[:near_completion].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.avg_progress') %>:</span> <strong><%= number_with_precision(collection_a[:average_progress], precision: 2, strip_insignificant_zeros: true) %>%</strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.unlocked_rewards') %>:</span> <strong><%= collection_a[:unlocked_reward_tiers].to_i %>/<%= collection_a[:reward_tiers_total].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.inconsistent_payload') %>:</span> <strong><%= collection_a[:inconsistent_progress_count].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.pending_materials_total') %>:</span> <strong><%= number_with_delimiter(collection_a[:pending_materials_total].to_i) %></strong></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <h3 class="h6 mb-3"><%= @result[:name_b] %></h3>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.total') %>:</span> <strong><%= collection_b[:total].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.completed') %>:</span> <strong><%= collection_b[:completed].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.in_progress') %>:</span> <strong><%= collection_b[:in_progress].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.near') %>:</span> <strong><%= collection_b[:near_completion].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.avg_progress') %>:</span> <strong><%= number_with_precision(collection_b[:average_progress], precision: 2, strip_insignificant_zeros: true) %>%</strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.unlocked_rewards') %>:</span> <strong><%= collection_b[:unlocked_reward_tiers].to_i %>/<%= collection_b[:reward_tiers_total].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.inconsistent_payload') %>:</span> <strong><%= collection_b[:inconsistent_progress_count].to_i %></strong></div>
                  <div><span class="text-muted"><%= t('armories.compare_overview.collection.pending_materials_total') %>:</span> <strong><%= number_with_delimiter(collection_b[:pending_materials_total].to_i) %></strong></div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-2 text-start mb-3">
            <div class="col-12">
              <small class="text-muted">
                <%= t('armories.compare_overview.collection.rationale_note') %>
              </small>
            </div>
          </div>

          <div class="row g-3 text-start mb-3">
            <div class="col-12 col-xl-6">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <h3 class="h6 mb-3"><%= t('armories.compare_overview.collection_targets.heading', name: @result[:name_a]) %></h3>
                  <% targets = Array(collection_a[:critical_targets]) %>
                  <% if targets.any? %>
                    <div class="table-responsive">
                      <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                          <tr>
                            <th><%= t('armories.compare_overview.collection_targets.table.collection') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.progress') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.pending') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.priority') %></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% targets.each do |target| %>
                            <tr>
                              <td>
                                <div><%= target[:tier] %> / <%= target[:collection_name] %></div>
                                <small class="text-muted">
                                  <%= t('armories.compare_overview.collection_targets.meta', impact: number_with_precision(target[:impact_score], precision: 2, strip_insignificant_zeros: true), effort: number_with_precision(target[:effort_score], precision: 2, strip_insignificant_zeros: true)) %>
                                </small>
                              </td>
                              <td class="text-center"><%= target[:progress].to_i %>%</td>
                              <td class="text-center"><%= number_with_delimiter(target[:pending_materials].to_i) %></td>
                              <td class="text-center fw-semibold"><%= number_with_precision(target[:priority_score], precision: 2, strip_insignificant_zeros: true) %></td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                  <% else %>
                    <small class="text-muted"><%= t('armories.compare_overview.collection_targets.empty') %></small>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="col-12 col-xl-6">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                  <h3 class="h6 mb-3"><%= t('armories.compare_overview.collection_targets.heading', name: @result[:name_b]) %></h3>
                  <% targets = Array(collection_b[:critical_targets]) %>
                  <% if targets.any? %>
                    <div class="table-responsive">
                      <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                          <tr>
                            <th><%= t('armories.compare_overview.collection_targets.table.collection') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.progress') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.pending') %></th>
                            <th class="text-center"><%= t('armories.compare_overview.collection_targets.table.priority') %></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% targets.each do |target| %>
                            <tr>
                              <td>
                                <div><%= target[:tier] %> / <%= target[:collection_name] %></div>
                                <small class="text-muted">
                                  <%= t('armories.compare_overview.collection_targets.meta', impact: number_with_precision(target[:impact_score], precision: 2, strip_insignificant_zeros: true), effort: number_with_precision(target[:effort_score], precision: 2, strip_insignificant_zeros: true)) %>
                                </small>
                              </td>
                              <td class="text-center"><%= target[:progress].to_i %>%</td>
                              <td class="text-center"><%= number_with_delimiter(target[:pending_materials].to_i) %></td>
                              <td class="text-center fw-semibold"><%= number_with_precision(target[:priority_score], precision: 2, strip_insignificant_zeros: true) %></td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                  <% else %>
                    <small class="text-muted"><%= t('armories.compare_overview.collection_targets.empty') %></small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-2 text-start">
            <div class="col-12 col-md-6 col-xl-3">
              <span class="text-muted"><%= t('armories.compare_overview.collection_diffs.completed') %>:</span>
              <span class="fw-semibold <%= collection_macro[:completed_diff].to_i >= 0 ? 'text-success' : 'text-danger' %>">
                <%= collection_macro[:completed_diff].to_i >= 0 ? '+' : '' %><%= collection_macro[:completed_diff].to_i %>
              </span>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
              <span class="text-muted"><%= t('armories.compare_overview.collection_diffs.avg_progress') %>:</span>
              <span class="fw-semibold <%= collection_macro[:average_progress_diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                <%= collection_macro[:average_progress_diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(collection_macro[:average_progress_diff], precision: 2, strip_insignificant_zeros: true) %>
              </span>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
              <span class="text-muted"><%= t('armories.compare_overview.collection_diffs.near') %>:</span>
              <span class="fw-semibold <%= collection_macro[:near_completion_diff].to_i >= 0 ? 'text-success' : 'text-danger' %>">
                <%= collection_macro[:near_completion_diff].to_i >= 0 ? '+' : '' %><%= collection_macro[:near_completion_diff].to_i %>
              </span>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
              <span class="text-muted"><%= t('armories.compare_overview.collection_diffs.unlocked_rewards') %>:</span>
              <span class="fw-semibold <%= collection_macro[:unlocked_reward_diff].to_i >= 0 ? 'text-success' : 'text-danger' %>">
                <%= collection_macro[:unlocked_reward_diff].to_i >= 0 ? '+' : '' %><%= collection_macro[:unlocked_reward_diff].to_i %>
              </span>
            </div>
          </div>
        </div>
      </section>

      <section class="armory-section-card">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_overview.progression_heading') %></h2>
        </div>
        <div class="armory-section-card__body p-0">
          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th><%= t('armories.compare_overview.table.system') %></th>
                  <th class="text-center"><%= @result[:name_a] %></th>
                  <th class="text-center"><%= @result[:name_b] %></th>
                  <th class="text-center"><%= t('armories.compare_overview.table.diff') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(@result[:progression_gaps]).each do |row| %>
                  <tr>
                    <td>
                      <div class="fw-semibold"><%= t("armories.compare_overview.systems.#{row[:label_key]}") %></div>
                      <small class="text-muted"><%= row[:detail_a] %> | <%= row[:detail_b] %></small>
                    </td>
                    <td class="text-center"><%= number_with_precision(row[:value_a], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center"><%= number_with_precision(row[:value_b], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center <%= row[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= row[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(row[:diff], precision: 2, strip_insignificant_zeros: true) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    <% elsif (params[:name_a].present? ^ params[:name_b].present?) %>
      <%= render 'info_alert',
                 message: t('armories.compare.hints.both_names_required'),
                 icon_class: 'fas fa-info-circle',
                 alert_classes: '' %>
    <% end %>
  </main>
</div>
