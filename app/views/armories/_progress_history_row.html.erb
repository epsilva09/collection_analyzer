<% snapshot = row[:snapshot] %>
<% delta_rate = row[:delta_completion_rate] %>
<% delta_completed = row[:delta_completed_collections] %>
<% snapshot_time = snapshot.respond_to?(:captured_at) && snapshot.captured_at.present? ? snapshot.captured_at : snapshot.captured_on.in_time_zone %>
<% snapshot_changed = snapshot.respond_to?(:has_changes) ? snapshot.has_changes : true %>
<% snapshot_changes_count = snapshot.respond_to?(:changes_count) ? snapshot.changes_count.to_i : nil %>

<tr>
  <td><%= snapshot_time.strftime('%Y-%m-%d %H:%M') %></td>
  <td class="text-end"><%= "#{snapshot.completed_collections}/#{snapshot.total_collections}" %></td>
  <td class="text-end"><%= number_to_percentage(snapshot.completion_rate, precision: 2) %></td>
  <td class="text-end <%= delta_rate.to_f.positive? ? 'text-success' : (delta_rate.to_f.negative? ? 'text-danger' : 'text-body-secondary') %>">
    <%= delta_rate.nil? ? t('armories.progress.history.no_delta') : format('%+.2f%%', delta_rate) %>
  </td>
  <td class="text-end <%= delta_completed.to_i.positive? ? 'text-success' : (delta_completed.to_i.negative? ? 'text-danger' : 'text-body-secondary') %>">
    <%= delta_completed.nil? ? t('armories.progress.history.no_delta') : format('%+d', delta_completed) %>
  </td>
  <td class="text-end">
    <% if snapshot_changed %>
      <span class="badge bg-success me-1"><%= t('armories.progress.history.changed_badge', count: snapshot_changes_count || 0) %></span>
    <% else %>
      <span class="badge bg-secondary me-1"><%= t('armories.progress.history.unchanged_badge') %></span>
    <% end %>
    <%= link_to t('armories.progress.history.view_changes'),
                progress_changes_armory_path(name: name, character_idx: snapshot.character_idx, snapshot_id: snapshot.id),
                class: 'btn btn-outline-secondary btn-sm' %>
  </td>
</tr>
