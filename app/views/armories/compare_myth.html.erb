<% content_for :title, t('armories.compare_myth.page_title') %>

<div class="container-fluid armory-layout-container">
  <main class="text-center armory-page armory-layout-main">
    <%= render 'locale_switcher' %>
    <%= render 'page_header', heading: t('armories.compare_myth.heading'), icon_class: nil %>

    <%= render 'menu',
               current_page: :compare_myth,
               name: (params[:name_a].presence || params[:name_b].presence),
               name_a: params[:name_a],
               name_b: params[:name_b],
               show_compare_actions: false %>

    <%= render 'compare_search_form', form_url: compare_myth_armory_path %>

    <% if @error.present? %>
      <%= render 'error_alert',
                 label: t('armories.compare.alerts.error'),
                 message: @error,
                 icon_class: nil,
                 dismissible: false %>
    <% end %>

    <% if @comparison_ready && @result.present? %>
      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_myth.summary_heading') %></h2>
        </div>
        <div class="armory-section-card__body">
          <div class="row g-3 text-start">
            <% Array(@result[:summary_cards]).each do |card| %>
              <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 bg-dark border-secondary">
                  <div class="card-body">
                    <div class="small armory-kpi-label"><%= t("armories.compare_myth.metrics.#{card[:label_key]}") %></div>
                    <div class="mt-2 armory-kpi-value"><span class="fw-semibold"><%= @result[:name_a] %>:</span> <span><%= number_with_delimiter(card[:value_a]) %></span></div>
                    <div class="armory-kpi-value"><span class="fw-semibold"><%= @result[:name_b] %>:</span> <span><%= number_with_delimiter(card[:value_b]) %></span></div>
                    <div class="mt-2 <%= card[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= card[:diff].to_f >= 0 ? '+' : '' %><%= number_with_delimiter(card[:diff]) %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </section>

      <% grade = @result[:grade_summary] || {} %>
      <% stigma = @result[:stigma_summary] || {} %>
      <% lines = @result[:line_summary] || {} %>
      <% grade_diff = grade[:grade_diff].to_i %>
      <% stigma_score_diff = stigma[:score_diff].to_i %>
      <% line_score_diff = lines[:total_score_diff].to_i %>
      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_myth.progression_heading') %></h2>
        </div>
        <div class="armory-section-card__body text-start">
          <div class="row g-3">
            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body myth-progress-card">
                  <h3 class="h6 mb-3"><%= t('armories.compare_myth.blocks.grade') %></h3>
                  <% grade_badge_class = grade_diff.positive? ? 'myth-advantage-badge myth-advantage-badge--a' : (grade_diff.negative? ? 'myth-advantage-badge myth-advantage-badge--b' : 'myth-advantage-badge myth-advantage-badge--tie') %>
                  <% grade_badge_text = grade_diff.positive? ? "#{@result[:name_a]} +#{grade_diff}" : (grade_diff.negative? ? "#{@result[:name_b]} +#{grade_diff.abs}" : 'Empate') %>
                  <div class="<%= grade_badge_class %>"><%= grade_badge_text %></div>
                  <div class="myth-kpi-grid mt-3">
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= @result[:name_a] %></span>
                      <strong class="d-block">G<%= grade[:grade_a].to_i %> - <%= grade[:grade_name_a].presence || '-' %></strong>
                    </div>
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= @result[:name_b] %></span>
                      <strong class="d-block">G<%= grade[:grade_b].to_i %> - <%= grade[:grade_name_b].presence || '-' %></strong>
                    </div>
                  </div>
                  <div class="myth-progress-row mt-3">
                    <div class="myth-progress-row__label"><%= t('armories.compare_myth.metrics.level_progress') %></div>
                    <div class="myth-progress-pair">
                      <span><%= @result[:name_a] %>: <strong><%= number_with_precision(grade[:level_progress_a], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-info" role="progressbar" style="width: <%= [[grade[:level_progress_a].to_f, 0].max, 100].min %>%"></div></div>
                      <span><%= @result[:name_b] %>: <strong><%= number_with_precision(grade[:level_progress_b], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-primary" role="progressbar" style="width: <%= [[grade[:level_progress_b].to_f, 0].max, 100].min %>%"></div></div>
                    </div>
                  </div>
                  <div class="myth-progress-row mt-2">
                    <div class="myth-progress-row__label"><%= t('armories.compare_myth.metrics.point_progress') %></div>
                    <div class="myth-progress-pair">
                      <span><%= @result[:name_a] %>: <strong><%= number_with_precision(grade[:point_progress_a], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-info" role="progressbar" style="width: <%= [[grade[:point_progress_a].to_f, 0].max, 100].min %>%"></div></div>
                      <span><%= @result[:name_b] %>: <strong><%= number_with_precision(grade[:point_progress_b], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-primary" role="progressbar" style="width: <%= [[grade[:point_progress_b].to_f, 0].max, 100].min %>%"></div></div>
                    </div>
                  </div>
                  <div class="armory-kpi-value mt-3"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.next_grade') %>:</span> <strong><%= grade.dig(:next_grade_a, :name).presence || '-' %></strong> vs <strong><%= grade.dig(:next_grade_b, :name).presence || '-' %></strong></div>
                  <div class="armory-kpi-value"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.next_grade_points') %>:</span> <strong><%= number_with_delimiter(grade.dig(:next_grade_a, :remaining_points).to_i) %></strong> vs <strong><%= number_with_delimiter(grade.dig(:next_grade_b, :remaining_points).to_i) %></strong></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body myth-progress-card">
                  <h3 class="h6 mb-3"><%= t('armories.compare_myth.blocks.stigma') %></h3>
                  <% stigma_badge_class = stigma_score_diff.positive? ? 'myth-advantage-badge myth-advantage-badge--a' : (stigma_score_diff.negative? ? 'myth-advantage-badge myth-advantage-badge--b' : 'myth-advantage-badge myth-advantage-badge--tie') %>
                  <% stigma_badge_text = stigma_score_diff.positive? ? "#{@result[:name_a]} +#{number_with_delimiter(stigma_score_diff)}" : (stigma_score_diff.negative? ? "#{@result[:name_b]} +#{number_with_delimiter(stigma_score_diff.abs)}" : 'Empate') %>
                  <div class="<%= stigma_badge_class %>"><%= stigma_badge_text %></div>
                  <div class="myth-kpi-grid mt-3">
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.stigma_score') %> (<%= @result[:name_a] %>)</span>
                      <strong class="d-block"><%= number_with_delimiter(stigma[:score_a].to_i) %></strong>
                    </div>
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.stigma_score') %> (<%= @result[:name_b] %>)</span>
                      <strong class="d-block"><%= number_with_delimiter(stigma[:score_b].to_i) %></strong>
                    </div>
                  </div>
                  <div class="armory-kpi-value mt-3"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.stigma_grade') %>:</span> <strong><%= stigma[:grade_a].to_i %></strong> vs <strong><%= stigma[:grade_b].to_i %></strong></div>
                  <div class="myth-progress-row mt-2">
                    <div class="myth-progress-row__label"><%= t('armories.compare_myth.metrics.stigma_progress') %></div>
                    <div class="myth-progress-pair">
                      <span><%= @result[:name_a] %>: <strong><%= number_with_precision(stigma[:progress_a], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-info" role="progressbar" style="width: <%= [[stigma[:progress_a].to_f, 0].max, 100].min %>%"></div></div>
                      <span><%= @result[:name_b] %>: <strong><%= number_with_precision(stigma[:progress_b], precision: 2, strip_insignificant_zeros: true) %>%</strong></span>
                      <div class="progress"><div class="progress-bar bg-primary" role="progressbar" style="width: <%= [[stigma[:progress_b].to_f, 0].max, 100].min %>%"></div></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-4">
              <div class="card bg-dark border-secondary h-100">
                <div class="card-body myth-progress-card">
                  <h3 class="h6 mb-3"><%= t('armories.compare_myth.blocks.lines') %></h3>
                  <% line_badge_class = line_score_diff.positive? ? 'myth-advantage-badge myth-advantage-badge--a' : (line_score_diff.negative? ? 'myth-advantage-badge myth-advantage-badge--b' : 'myth-advantage-badge myth-advantage-badge--tie') %>
                  <% line_badge_text = line_score_diff.positive? ? "#{@result[:name_a]} +#{number_with_delimiter(line_score_diff)}" : (line_score_diff.negative? ? "#{@result[:name_b]} +#{number_with_delimiter(line_score_diff.abs)}" : 'Empate') %>
                  <div class="<%= line_badge_class %>"><%= line_badge_text %></div>
                  <div class="myth-kpi-grid mt-3">
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.line_total_score') %> (<%= @result[:name_a] %>)</span>
                      <strong class="d-block"><%= number_with_delimiter(lines[:total_score_a].to_i) %></strong>
                    </div>
                    <div class="myth-kpi-grid__item">
                      <span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.line_total_score') %> (<%= @result[:name_b] %>)</span>
                      <strong class="d-block"><%= number_with_delimiter(lines[:total_score_b].to_i) %></strong>
                    </div>
                  </div>
                  <div class="armory-kpi-value mt-3"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.line_nodes') %>:</span> <strong><%= lines[:total_nodes_a].to_i %></strong> vs <strong><%= lines[:total_nodes_b].to_i %></strong></div>
                  <div class="armory-kpi-value"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.line_unlocked') %>:</span> <strong><%= lines[:unlocked_a].to_i %></strong> vs <strong><%= lines[:unlocked_b].to_i %></strong></div>
                  <div class="armory-kpi-value"><span class="armory-kpi-label"><%= t('armories.compare_myth.metrics.line_avg_level') %>:</span> <strong><%= number_with_precision(lines[:avg_level_a], precision: 2, strip_insignificant_zeros: true) %></strong> vs <strong><%= number_with_precision(lines[:avg_level_b], precision: 2, strip_insignificant_zeros: true) %></strong></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_myth.lines_score_heading') %></h2>
        </div>
        <div class="armory-section-card__body p-0">
          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th class="text-center"><%= t('armories.compare_myth.table.line_id') %></th>
                  <th class="text-center"><%= @result[:name_a] %></th>
                  <th class="text-center"><%= @result[:name_b] %></th>
                  <th class="text-center"><%= t('armories.compare_myth.table.score_diff') %></th>
                  <th class="text-center"><%= t('armories.compare.table.winner') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(@result[:line_id_rows]).each do |row| %>
                  <% row_view = compare_row_presentation({ diff: row[:diff], unit: nil }, name_a: @result[:name_a], name_b: @result[:name_b]) %>
                  <tr class="<%= row[:top_for_a] || row[:top_for_b] ? 'special-attribute-row' : '' %>">
                    <td class="text-center fw-semibold">#<%= row[:id] %></td>
                    <td class="text-center">
                      <strong><%= number_with_delimiter(row[:points_a]) %></strong>
                      <div class="small armory-kpi-label mt-1"><%= row[:attribute_a].presence || row[:name_a].presence || '-' %></div>
                      <div class="small text-info mt-1"><%= row[:value_label_a].presence || '-' %></div>
                    </td>
                    <td class="text-center">
                      <strong><%= number_with_delimiter(row[:points_b]) %></strong>
                      <div class="small armory-kpi-label mt-1"><%= row[:attribute_b].presence || row[:name_b].presence || '-' %></div>
                      <div class="small text-info mt-1"><%= row[:value_label_b].presence || '-' %></div>
                    </td>
                    <td class="text-center <%= row[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= row[:diff].to_f >= 0 ? '+' : '' %><%= number_with_delimiter(row[:diff]) %>
                    </td>
                    <td class="text-center">
                      <span class="<%= row_view[:winner_bg] %> <%= row_view[:winner_text] %> fw-bold d-inline-block px-2 py-1 rounded">
                        <i class="<%= row_view[:winner_icon] %> me-1"></i><%= row_view[:winner] %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="armory-section-card mb-4">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_myth.lines_heading') %></h2>
        </div>
        <div class="armory-section-card__body p-0">
          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th><%= t('armories.compare_myth.table.attribute') %></th>
                  <th class="text-center"><%= @result[:name_a] %></th>
                  <th class="text-center"><%= @result[:name_b] %></th>
                  <th class="text-center"><%= t('armories.compare_myth.table.diff') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(@result[:line_attribute_rows]).each do |row| %>
                  <tr class="<%= row[:is_special] ? 'special-attribute-row' : '' %>">
                    <td>
                      <% if row[:is_special] %>
                        <i class="fas fa-star me-1"></i>
                      <% end %>
                      <%= row[:attribute] %>
                    </td>
                    <td class="text-center"><%= number_with_precision(row[:value_a], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center"><%= number_with_precision(row[:value_b], precision: 2, strip_insignificant_zeros: true) %></td>
                    <td class="text-center <%= row[:diff].to_f >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= row[:diff].to_f >= 0 ? '+' : '' %><%= number_with_precision(row[:diff], precision: 2, strip_insignificant_zeros: true) %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="armory-section-card">
        <div class="armory-section-card__header">
          <h2 class="armory-section-card__title"><%= t('armories.compare_myth.grades_heading') %></h2>
        </div>
        <div class="armory-section-card__body p-0">
          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle armory-data-table">
              <thead>
                <tr>
                  <th><%= t('armories.compare_myth.table.grade') %></th>
                  <th><%= @result[:name_a] %></th>
                  <th><%= @result[:name_b] %></th>
                  <th><%= t('armories.compare_myth.table.status') %></th>
                </tr>
              </thead>
              <tbody>
                <% Array(@result[:grade_rows]).each do |row| %>
                  <tr>
                    <td>G<%= row[:grade].to_i %></td>
                    <td>
                      <div class="fw-semibold"><%= row[:name_a].presence || '-' %></div>
                      <small class="text-muted"><%= row[:force_a].presence || '-' %></small>
                    </td>
                    <td>
                      <div class="fw-semibold"><%= row[:name_b].presence || '-' %></div>
                      <small class="text-muted"><%= row[:force_b].presence || '-' %></small>
                    </td>
                    <td><%= t("armories.compare_myth.status.#{row[:status]}") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    <% elsif (params[:name_a].present? ^ params[:name_b].present?) %>
      <%= render 'info_alert',
                 message: t('armories.compare.hints.both_names_required'),
                 icon_class: 'fas fa-info-circle',
                 alert_classes: '' %>
    <% end %>
  </main>
</div>
